# --- Drishti tools (seed + simulator) ---
# Copy to .env and fill in. Never commit .env.

# Used by seed.js to write directly to the database.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=drishti

# Used by simulator.js to POST readings to the ingest API.
# Local dev: http://localhost:3000/api/ingest
# Deployed:  https://<your-client-app>.vercel.app/api/ingest
INGEST_URL=http://localhost:3000/api/ingest

# Must match INGEST_API_KEY in the client app's env.
INGEST_API_KEY=change-me-to-a-long-random-string

# Vehicle the simulator drives (must exist in the vehicles collection — seed creates it).
SIM_VEHICLE=HR20AP1234

# How often (ms) the simulator sends a reading.
SIM_INTERVAL_MS=5000
