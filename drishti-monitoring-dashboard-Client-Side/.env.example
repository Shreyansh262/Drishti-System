# --- Drishti client (driver dashboard) ---
# Copy this file to .env.local and fill in your own values. Never commit .env.local.

# MongoDB Atlas connection string (free M0 tier).
# Get it from: Atlas > Database > Connect > Drivers
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=drishti

# Shared secret required in the `x-ingest-key` header to POST to /api/ingest.
# Use any long random string; the device/simulator must send the same value.
INGEST_API_KEY=change-me-to-a-long-random-string

# Maps are now free OpenStreetMap (Leaflet) — no API key needed.
