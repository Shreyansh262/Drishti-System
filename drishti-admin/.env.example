# --- Drishti admin panel ---
# Copy this file to .env.local and fill in your own values. Never commit .env.local.

# Use the SAME MongoDB Atlas connection + DB name as the client app so the
# admin panel reads/writes the same data.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=drishti
